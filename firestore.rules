// ============================================================================
// PLACEHOLDER — DO NOT DEPLOY AS-IS
// ============================================================================
// These rules are a locked-down default. Before enabling deployment, paste
// in the CURRENT live rules from the Firebase console so you don't overwrite
// them. Steps:
//   1. https://console.firebase.google.com/project/personal-site-5bca5/firestore/rules
//   2. Copy the live rules, replace the block below with them.
//   3. Wire deployment by adding a "firestore" section to firebase.json:
//        "firestore": {
//          "rules": "firestore.rules",
//          "indexes": "firestore.indexes.json"
//        }
//   4. Deploy with: firebase deploy --only firestore:rules
// ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if
          request.time < timestamp.date(2022, 8, 7);
    }
  }
}
