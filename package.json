{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && firebase deploy",
    "lint": "eslint src --ext .js,.vue"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.2.2",
    "firebase": "^9.9.0",
    "moment": "^2.29.3",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "vuetify": "^3.12.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "sass": "^1.80.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es2022": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "vue/multi-word-component-names": "off",
      "vue/no-reserved-component-names": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
